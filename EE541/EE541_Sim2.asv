clc; clear; close all;

N = 10;
% Assuming d = lambda/2
d = 0.5;
%Scenarios
u_s = 0; % Broadside 90 degrees
u_I = [0.18 0.3];
SNR_dB = [0 10];
INR_dB = [0 10];


n   = (-(N-1)/2 : (N-1)/2)';
u   = linspace(-1, 1, 1000);

% Array Manifold function
va = @(u0) exp(1j*2*pi*d*n*u0);
% Beam pattern func
BP = @(w0, u_arr) abs(exp(-1j*2*pi*d * u_arr(:) * n') * w0); 

